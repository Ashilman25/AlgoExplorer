# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./app/app.db
# Production (Render): set automatically via fromDatabase (PostgreSQL connection string)

# ── Environment ───────────────────────────────────────────
ENV=development
# Production: production

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production: not set (unused)

USE_REDIS=true
# Production: false (benchmarks run in-process, rate limiting uses in-memory)

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:4175
# Production: https://yourdomain.com,https://www.yourdomain.com

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
# Production: WARNING

# ── Security ──────────────────────────────────────────────
ENFORCE_HTTPS=false
# Production: true

# ── Auth ──────────────────────────────────────────────────
AUTH_SESSION_HOURS=168
AUTH_PASSWORD_ITERATIONS=600000

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_GENERAL=30/minute
RATE_LIMIT_READONLY=60/minute
RATE_LIMIT_STORAGE_URI=redis://localhost:6379/1
# Production: not set (falls back to in-memory)

# ── Account Lockout ───────────────────────────────────────
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ── Benchmarks ────────────────────────────────────────────
BENCHMARK_QUEUE_NAME=benchmarks
BENCHMARK_PROGRESS_INTERVAL=1
